{
  "name": "sentiment-analysis-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node --watch server/index.js\" \"vite --config client/vite.config.js\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite --config client/vite.config.js",
    "build": "vite build --config client/vite.config.js",
    "start": "node server/index.js",
    "test": "node --test tests/**/*.test.js"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.0.0",
    "@better-auth/mongo-adapter": "^1.3.8",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "csv-stringify": "^6.5.2",
    "better-auth": "^1.3.8",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "mongodb": "^6.18.0",
    "mongoose": "^8.18.1",
    "multer": "^2.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.1",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "vite": "^6.1.0"
  }
}
